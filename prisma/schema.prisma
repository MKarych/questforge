generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USER — Aggregate Root
// Одна таблица с JSON-полями для MVP.
// Потом разделим на отдельные сущности.
// ============================================================

model User {
  // === IDENTITY ===
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @db.VarChar(255)
  username  String   @unique @db.VarChar(100)
  slug      String   @unique @db.VarChar(150)
  roles     Role[]   @default([PLAYER])
  status    UserStatus @default(ACTIVE)
  verified  Json     @default("{}") @map("verified") // { email: bool, phone: bool, telegram: bool }
  version   Int      @default(1) // Optimistic locking

  // === AUTH ===
  isEmailVerified   Boolean  @default(false) @map("is_email_verified")
  verificationToken String?  @unique @map("verification_token") @db.VarChar(255)

  // === PROFILE (JSON) ===
  // { avatar, bio, city, socialLinks: { tg, vk, discord, youtube, github }, favorites: { games, scenarios, authors }, metadata }
  profile   Json     @default("{}") @map("profile")

  // === SETTINGS (JSON) ===
  // { language, timezone, theme, notifications: { email, telegram, push }, privacy: { showCity, showContacts, showStats, showAchievements } }
  settings  Json     @default("{}") @map("settings")

  // === SECURITY (JSON) — управляется Auth Service ===
  // { lastLoginAt, failedLoginAttempts, passwordChangedAt, trustedDevices: [] }
  security  Json     @default("{}") @map("security")

  // === REPUTATION (JSON) — вычисляется системой ===
  // { rating, trustScore, reviewsCount, violations, completedGames, achievements: [] }
  reputationData Json @default("{}") @map("reputation_data")

  // === AI PROFILE (JSON) — принадлежит AI Service ===
  // { preferences: { genres, averageTeamSize, averageGameDuration, favoriteDifficulty }, memory: { knownFacts, lastConversation, memoryVersion }, history: { recommendedScenarios, previousActions, feedback }, context: { lastAgentAction, activeGoals, personality }, embeddings: [] }
  aiProfile  Json    @default("{}") @map("ai_profile")

  // === CAPABILITIES (JSON) — вычисляются системой ===
  capabilities Json  @default("[]") @map("capabilities")
  featureFlags Json  @default("{}") @map("feature_flags")

  // === AUDIT ===
  lastSeenAt DateTime? @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at") // Soft Delete

  // === СТАРЫЕ ПОЛЯ (обратная совместимость) ===
  name             String           @db.VarChar(100)
  passwordHash     String           @map("password_hash") @db.VarChar(255)
  avatarUrl        String?          @map("avatar_url")
  role             Role             @default(PLAYER)
  contacts         Json             @default("{}")
  organizerStatus  OrganizerStatus  @default(NOT_APPLIED) @map("organizer_status")
  organizerApprovedAt DateTime?     @map("organizer_approved_at")
  gamesConducted   Int              @default(0) @map("games_conducted")
  gamesCreated     Int              @default(0) @map("games_created")
  organizerApplicationId String?    @map("organizer_application_id") @db.Uuid
  scenariosCreated Int              @default(0) @map("scenarios_created")
  rating           Float            @default(0)
  reputation       Int              @default(0)
  legacyAchievements Json           @default("[]") @map("achievements") @db.Json
  lastLoginAt      DateTime?        @map("last_login_at")
  bio              String?
  city             String?          @db.VarChar(100)
  telegram         String?          @db.VarChar(100)
  vk               String?          @db.VarChar(255)
  whatsapp         String?          @db.VarChar(100)

  // === RELATIONS ===
  comments               Comment[]
  games                  Game[]
  mediaUploads           Media[]                @relation("MediaUploader")
  reviewedApplications   OrganizerApplication[] @relation("ApplicationReviewer")
  organizerApplication   OrganizerApplication?
  reviews                Review[]
  scenarios              Scenario[]
  createdVersions        ScenarioVersion[]

  // === COMMERCE RELATIONS ===
  marketplaceListings    MarketplaceListing[]
  userLicenses           UserLicense[]
  scenarioRuns           ScenarioRun[]
  purchases              Purchase[]
  favoriteListings       FavoriteListing[]
  cart                   Cart?
  authoredEarnings       AuthorEarning[]
  payouts                Payout[]
  marketplaceReviews     MarketplaceReview[]
  promoCodesCreated      PromoCode[]
  captainTeams           Team[]                 @relation("TeamCaptain")
  teamMemberships        TeamMember[]
  auditLogs              AuditLog[]
  followers              Follow[]               @relation("FollowTarget")
  following              Follow[]               @relation("FollowSource")
  activityLogs           ActivityLog[]
  teamInvitesReceived    TeamInvite[]           @relation("InvitedUser")
  teamInvitesSent        TeamInvite[]           @relation("InvitedByUser")
  joinRequests           JoinRequest[]
  joinRequestsResolved   JoinRequest[]          @relation("JoinRequestResolver")
  transfersFrom          OwnershipTransfer[]    @relation("TransferFrom")
  transfersTo            OwnershipTransfer[]    @relation("TransferTo")
  gameComments           GameComment[]
  gameQuestions          GameQuestion[]
  notifications          Notification[]
  achievements           UserAchievement[]
  userLimits             UserLimits?
  ledgerEntries          LedgerEntry[]
  payments               Payment[]
  supportTickets         SupportTicket[]
  assignedSupportTickets SupportTicket[] @relation("SupportAssignee")

  // === SOCIAL RELATIONS ===
  friends                Friend[]               @relation("FriendTarget")
  friendsOf              Friend[]               @relation("FriendSource")
  sentFriendRequests     FriendRequest[]        @relation("FriendRequestSender")
  receivedFriendRequests FriendRequest[]        @relation("FriendRequestReceiver")
  blockedUsers           BlockedUser[]          @relation("BlockedUserTarget")
  blockedBy              BlockedUser[]          @relation("BlockedUserSource")
  chatsAsUser1           Chat[]                 @relation("ChatUser1")
  chatsAsUser2           Chat[]                 @relation("ChatUser2")
  chatMessages           ChatMessage[]

  @@index([email])
  @@index([username])
  @@index([slug])
  @@index([status])
  @@index([city])
  @@index([rating])
}

// ============================================================
// SOCIAL — FRIENDS, FRIEND REQUESTS, BLOCKED USERS
// ============================================================

model Friend {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  friendId         String   @map("friend_id") @db.Uuid
  addedAt          DateTime @default(now()) @map("added_at")
  lastInteraction  DateTime @default(now()) @map("last_interaction")

  user   User @relation("FriendSource", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendTarget", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
  @@map("friends")
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

model FriendRequest {
  id         String              @id @default(uuid()) @db.Uuid
  fromUserId String              @map("from_user_id") @db.Uuid
  toUserId   String              @map("to_user_id") @db.Uuid
  status     FriendRequestStatus @default(PENDING)
  message    String?             @db.Text
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  fromUser User @relation("FriendRequestSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("FriendRequestReceiver", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([status])
  @@map("friend_requests")
}

model BlockedUser {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  blockedId   String   @map("blocked_id") @db.Uuid
  reason      String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  user   User @relation("BlockedUserSource", fields: [userId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockedUserTarget", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([userId, blockedId])
  @@index([userId])
  @@index([blockedId])
  @@map("blocked_users")
}

// ============================================================
// CHATS & MESSAGES
// ============================================================

model Chat {
  id          String   @id @default(uuid()) @db.Uuid
  user1Id     String   @map("user1_id") @db.Uuid
  user2Id     String   @map("user2_id") @db.Uuid
  lastMessage String?  @db.Text
  lastMessageAt DateTime? @map("last_message_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user1    User          @relation("ChatUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User          @relation("ChatUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@index([lastMessageAt])
  @@map("chats")
}

model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  chatId    String   @map("chat_id") @db.Uuid
  senderId  String   @map("sender_id") @db.Uuid
  text      String   @db.Text
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")

  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id])

  @@index([chatId])
  @@index([chatId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}

// ============================================================
// SUPPORT TICKETS
// ============================================================

enum SupportTicketStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

model SupportTicket {
  id          String               @id @default(uuid()) @db.Uuid
  userId      String?              @map("user_id") @db.Uuid
  email       String               @db.VarChar(255)
  name        String               @db.VarChar(200)
  category    String               @db.VarChar(100)
  message     String               @db.Text
  attachments Json                 @default("[]")
  status      SupportTicketStatus  @default(NEW)
  assignedTo  String?              @map("assigned_to") @db.Uuid
  response    String?              @db.Text
  resolvedAt  DateTime?            @map("resolved_at")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  user      User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  assignee  User? @relation("SupportAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
  @@index([assignedTo])
  @@index([createdAt])
  @@map("support_tickets")
}

// ============================================================
// FOLLOW SYSTEM
// ============================================================

model Follow {
  id          String   @id @default(uuid()) @db.Uuid
  followerId  String   @map("follower_id") @db.Uuid
  followingId String   @map("following_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  follower    User     @relation("FollowSource", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("FollowTarget", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)
  entityId  String   @map("entity_id") @db.VarChar(100)
  oldValue  Json?
  newValue  Json?
  ip        String?  @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entity, entityId])
}

// ============================================================
// USER ACHIEVEMENT (достижения пользователя)
// ============================================================

model UserAchievement {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  type        String   @db.VarChar(50)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  icon        String   @default("🏆") @db.VarChar(50)
  unlockedAt  DateTime @default(now()) @map("unlocked_at")
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, type])
  @@index([userId])
  @@index([type])
}

// ============================================================
// NOTIFICATION (уведомления пользователя)
// ============================================================

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(255)
  message   String?  @db.Text
  link      String?  @db.VarChar(500)
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
}

// ============================================================
// ACTIVITY LOG (лента действий пользователя)
// ============================================================

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

// ============================================================
// ACTIVITY EVENT (живая лента "Прямо сейчас")
// ============================================================

enum ActivityEventType {
  GAME_STARTED
  GAME_FINISHED
  TEAM_CREATED
  SCENARIO_PUBLISHED
  REVIEW_LEFT
  USER_REGISTERED
  ACHIEVEMENT_UNLOCKED
}

model ActivityEvent {
  id         String             @id @default(uuid()) @db.Uuid
  type       ActivityEventType  @map("type")
  userId     String             @map("user_id") @db.Uuid
  userName   String             @map("user_name") @db.VarChar(100)
  userAvatar String?            @map("user_avatar")
  payload    Json               @default("{}")
  createdAt  DateTime           @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([type])
  @@index([userId])
  @@map("activity_events")
}

// ============================================================
// GAME — Aggregate Root
// ============================================================

model Game {
  id                String           @id @default(uuid()) @db.Uuid
  slug              String           @unique @db.VarChar(150)
  title             String           @db.VarChar(255)
  description       String?
  city              String           @db.VarChar(100)
  address           String?          @db.VarChar(500)
  date              DateTime
  time              String           @db.VarChar(5) // HH:mm
  duration          Int              @map("duration")
  price             Decimal          @default(0) @db.Decimal(10, 2)
  maxTeams          Int              @default(50) @map("max_teams")
  shareLink         String           @unique @map("share_link") @db.VarChar(50)
  imageUrl          String?          @map("image_url")
  bannerUrl         String?          @map("banner_url")
  tags              String[]         @default([]) @map("tags")
  status            GameStatus       @default(DRAFT)
  moderationComment String?          @map("moderation_comment")
  version           Int              @default(1) // Optimistic locking

  // Настройки старта
  autoStart         Boolean          @default(false) @map("auto_start")
  autoStartDelay    Int              @default(0) @map("auto_start_delay")
  allowEarlyStart   Boolean          @default(true) @map("allow_early_start")
  startBuffer       Int              @default(15) @map("start_buffer")
  allowLateRegistration Boolean       @default(false) @map("allow_late_registration")

  organizerId       String           @map("organizer_id") @db.Uuid
  scenarioId        String?          @map("scenario_id") @db.Uuid

  publishedAt       DateTime?        @map("published_at")
  startedAt         DateTime?        @map("started_at")
  finishedAt        DateTime?        @map("finished_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  deletedAt         DateTime?        @map("deleted_at")

  // Relations
  organizer         User             @relation(fields: [organizerId], references: [id])
  scenario          Scenario?        @relation(fields: [scenarioId], references: [id])
  comments          Comment[]
  events            Event[]
  gameTeams         GameTeam[]
  registrations     GameRegistration[]
  gameComments           GameComment[]
  gameQuestions          GameQuestion[]
  heatmapData       HeatmapData[]
  media             Media[]
  reviews           Review[]

  @@index([shareLink])
  @@index([organizerId])
  @@index([status])
  @@index([city])
  @@index([date])
  @@index([scenarioId])
  @@index([slug])
  @@index([deletedAt])
}

// ============================================================
// GAME REGISTRATION
// ============================================================

model GameRegistration {
  id        String             @id @default(uuid()) @db.Uuid
  gameId    String             @map("game_id") @db.Uuid
  teamId    String             @map("team_id") @db.Uuid
  status    RegistrationStatus @default(REGISTERED)
  readyAt   DateTime?          @map("ready_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  game      Game               @relation(fields: [gameId], references: [id], onDelete: Cascade)
  team      Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([gameId, teamId])
  @@index([gameId])
  @@index([teamId])
  @@index([status])
}

// ============================================================
// GAME COMMENT (обсуждения игры)
// ============================================================

model GameComment {
  id        String   @id @default(uuid()) @db.Uuid
  gameId    String   @map("game_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  text      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])

  @@index([gameId])
  @@index([authorId])
  @@index([createdAt])
}

// ============================================================
// GAME QUESTION (вопросы организатору)
// ============================================================

model GameQuestion {
  id         String    @id @default(uuid()) @db.Uuid
  gameId     String    @map("game_id") @db.Uuid
  authorId   String    @map("author_id") @db.Uuid
  question   String    @db.Text
  answer     String?   @db.Text
  answeredAt DateTime? @map("answered_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  game       Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  author     User      @relation(fields: [authorId], references: [id])

  @@index([gameId])
  @@index([authorId])
  @@index([answeredAt])
}

// ============================================================
// SCENARIO
// ============================================================

model Scenario {
  id               String            @id @default(uuid()) @db.Uuid
  name             String            @db.VarChar(255)
  description      String?
  authorId         String            @map("author_id") @db.Uuid
  version          Int               @default(1)
  isPublished      Boolean           @default(false) @map("is_published")
  price            Decimal?          @db.Decimal(10, 2)
  licenseType      String?           @map("license_type") @db.VarChar(50)
  nodes            Json              @default("[]")
  edges            Json              @default("[]")
  startNodeId      String            @map("start_node_id") @db.VarChar(50)
  metadata         Json              @default("{}")
  validationStatus String?           @map("validation_status") @db.VarChar(50)
  validationErrors Json?             @map("validation_errors")
  publishedAt      DateTime?         @map("published_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")
  games            Game[]
  author           User              @relation(fields: [authorId], references: [id])
  listing          MarketplaceListing?
  versions         ScenarioVersion[]

  @@index([authorId])
  @@index([isPublished])
  @@index([price])
  @@index([validationStatus])
}

// ============================================================
// TEAM — Aggregate Root
// ============================================================

model Team {
  id            String         @id @default(uuid()) @db.Uuid
  name          String         @db.VarChar(100)
  slug          String         @unique @db.VarChar(150)
  description   String?        @db.Text
  avatar        String?        @db.VarChar(500)
  banner        String?        @db.VarChar(500)
  city          String?        @db.VarChar(100)
  country       String?        @db.VarChar(100)
  website       String?        @db.VarChar(500)
  socials       Json           @default("{}") @map("socials") // { discord, vk, telegram, youtube }
  captainId     String         @map("captain_id") @db.Uuid
  status        TeamStatus     @default(ACTIVE) @map("status")
  privacy       TeamVisibility @default(PUBLIC) @map("privacy")
  joinPolicy    JoinPolicy     @default(INVITE_ONLY) @map("join_policy")
  tags          String[]       @default([]) @map("tags")
  version       Int            @default(1) // Optimistic locking
  score         Int            @default(0)
  penalties     Int            @default(0)
  finishedAt    DateTime?      @map("finished_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at") // Soft Delete

  // Limits (JSON)
  maxMembers           Int  @default(20) @map("max_members")
  maxInvitesPerDay     Int  @default(10) @map("max_invites_per_day")
  maxPendingRequests   Int  @default(5) @map("max_pending_requests")
  maxChatMessagesPerMinute Int @default(30) @map("max_chat_messages_per_minute")

  // Relations
  captain       User           @relation("TeamCaptain", fields: [captainId], references: [id])
  members       TeamMember[]
  invites       TeamInvite[]
  joinRequests  JoinRequest[]
  transfers     OwnershipTransfer[]
  events        Event[]
  games         GameTeam[]
  registrations GameRegistration[]
  heatmapData   HeatmapData[]
  inventory     Inventory?
  media         Media[]
  resources     Resource?
  sessionStates SessionState[]

  @@index([captainId])
  @@index([status])
  @@index([slug])
  @@index([city])
  @@index([deletedAt])
}

model TeamMember {
  id        String      @id @default(uuid()) @db.Uuid
  teamId    String      @map("team_id") @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  role      TeamRole    @default(MEMBER) @map("role")
  status    MemberStatus @default(ACTIVE) @map("status")
  joinedAt  DateTime    @default(now()) @map("joined_at")
  leftAt    DateTime?   @map("left_at")
  lastActiveAt DateTime? @map("last_active_at")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  team      Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])

  @@unique([teamId, userId], name: "team_member_unique")
  @@index([teamId])
  @@index([userId])
  @@index([role])
  @@index([status])
}

// ============================================================
// TEAM INVITE
// ============================================================

model TeamInvite {
  id            String       @id @default(uuid()) @db.Uuid
  teamId        String       @map("team_id") @db.Uuid
  invitedUserId String       @map("invited_user_id") @db.Uuid
  invitedBy     String       @map("invited_by") @db.Uuid
  token         String       @unique @db.VarChar(255)
  message       String?      @db.Text
  status        InviteStatus @default(PENDING) @map("status")
  expiresAt     DateTime     @map("expires_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  team          Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedUser   User         @relation("InvitedUser", fields: [invitedUserId], references: [id])
  invitedByUser User         @relation("InvitedByUser", fields: [invitedBy], references: [id])

  @@index([teamId])
  @@index([invitedUserId])
  @@index([token])
  @@index([status])
  @@index([expiresAt])
}

// ============================================================
// JOIN REQUEST
// ============================================================

model JoinRequest {
  id         String            @id @default(uuid()) @db.Uuid
  teamId     String            @map("team_id") @db.Uuid
  userId     String            @map("user_id") @db.Uuid
  message    String?           @db.Text
  status     JoinRequestStatus @default(PENDING) @map("status")
  resolvedBy String?           @map("resolved_by") @db.Uuid
  createdAt  DateTime          @default(now()) @map("created_at")
  resolvedAt DateTime?         @map("resolved_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  team       Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id])
  resolver   User?             @relation("JoinRequestResolver", fields: [resolvedBy], references: [id])

  @@unique([teamId, userId, status], name: "join_request_unique")
  @@index([teamId])
  @@index([userId])
  @@index([status])
}

// ============================================================
// OWNERSHIP TRANSFER
// ============================================================

model OwnershipTransfer {
  id          String          @id @default(uuid()) @db.Uuid
  teamId      String          @map("team_id") @db.Uuid
  fromUserId  String          @map("from_user_id") @db.Uuid
  toUserId    String          @map("to_user_id") @db.Uuid
  status      TransferStatus  @default(PENDING) @map("status")
  expiresAt   DateTime        @map("expires_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  resolvedAt  DateTime?       @map("resolved_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  team        Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  fromUser    User            @relation("TransferFrom", fields: [fromUserId], references: [id])
  toUser      User            @relation("TransferTo", fields: [toUserId], references: [id])

  @@index([teamId])
  @@index([status])
  @@index([expiresAt])
}

model GameTeam {
  id       String   @id @default(uuid()) @db.Uuid
  teamId   String   @map("team_id") @db.Uuid
  gameId   String   @map("game_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at")
  game     Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, gameId])
  @@index([teamId])
  @@index([gameId])
}

// ============================================================
// INVENTORY & RESOURCES
// ============================================================

model Inventory {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @unique @map("team_id") @db.Uuid
  items     Json     @default("[]")
  capacity  Int      @default(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

model Resource {
  id         String   @id @default(uuid()) @db.Uuid
  teamId     String   @unique @map("team_id") @db.Uuid
  score      Int      @default(0)
  reputation Int      @default(0)
  money      Int      @default(0)
  energy     Int      @default(100)
  lives      Int      @default(3)
  custom     Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

// ============================================================
// SESSION STATE
// ============================================================

model SessionState {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  state     Json
  sequence  Int
  createdAt DateTime @default(now()) @map("created_at")
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([sequence])
}

// ============================================================
// EVENT (Game Engine Events)
// ============================================================

model Event {
  id        String   @id @default(uuid()) @db.Uuid
  type      String   @db.VarChar(50)
  gameId    String   @map("game_id") @db.Uuid
  teamId    String?  @map("team_id") @db.Uuid
  nodeId    String?  @map("node_id") @db.VarChar(50)
  payload   Json     @default("{}")
  timestamp DateTime
  sequence  Int
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  game      Game     @relation(fields: [gameId], references: [id])
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([teamId])
  @@index([type])
  @@index([sequence])
  @@index([createdAt])
  @@index([gameId, createdAt])
  @@index([teamId, createdAt])
}

// ============================================================
// COMMERCE MODULE — Marketplace, Licensing, Payments
// ============================================================

// ============================================================
// MarketplaceListing — витрина сценария
// ============================================================

enum ListingStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
  BLOCKED
  ARCHIVED
}

enum LicenseType {
  SINGLE
  MULTI_CITY
  COMMERCIAL
  WHITE_LABEL
}

enum UpdatePolicy {
  ALL_UPDATES
  MAJOR_ONLY
  FIXES_ONLY
  NO_UPDATES
}

model MarketplaceListing {
  id          String        @id @default(uuid()) @db.Uuid
  scenarioId  String        @unique @map("scenario_id") @db.Uuid
  authorId    String        @map("author_id") @db.Uuid

  // Основная информация
  title       String        @db.VarChar(255)
  description String?       @db.Text
  shortDescription String?  @map("short_description") @db.VarChar(500)
  category    String?       @db.VarChar(100)
  tags        String[]      @default([])
  coverUrl    String?       @map("cover_url") @db.VarChar(500)
  bannerUrl   String?       @map("banner_url") @db.VarChar(500)

  // Ценообразование
  price       Decimal       @db.Decimal(10, 2)
  licenseType LicenseType   @default(SINGLE) @map("license_type")
  updatePolicy UpdatePolicy @default(ALL_UPDATES) @map("update_policy")

  // Статус модерации
  status            ListingStatus @default(DRAFT)
  moderationComment String?       @map("moderation_comment")
  moderatedBy       String?       @map("moderated_by") @db.Uuid
  moderatedAt       DateTime?     @map("moderated_at")

  // Версия сценария, которая опубликована в маркетплейсе
  publishedVersionId String? @map("published_version_id") @db.Uuid

  // Статистика (denormalized)
  views       Int @default(0)
  favorites   Int @default(0)
  sales       Int @default(0)
  avgRating   Float @default(0) @map("avg_rating")
  reviewsCount Int @default(0) @map("reviews_count")

  // Audit
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  scenario    Scenario          @relation(fields: [scenarioId], references: [id])
  author      User              @relation(fields: [authorId], references: [id])
  licenses    UserLicense[]
  purchases   Purchase[]
  favoritedBy FavoriteListing[] @relation("ListingFavorites")
  cartItems   CartItem[]
  reviews     MarketplaceReview[]
  analytics   MarketplaceAnalytics[]

  @@index([authorId])
  @@index([status])
  @@index([category])
  @@index([price])
  @@index([avgRating])
  @@index([sales])
  @@index([createdAt])
  @@map("marketplace_listings")
}

// ============================================================
// ScenarioVersion — версии сценария
// ============================================================

enum VersionStatus {
  DRAFT
  PUBLISHED
  DEPRECATED
  ARCHIVED
}

model ScenarioVersion {
  id          String        @id @default(uuid()) @db.Uuid
  scenarioId  String        @map("scenario_id") @db.Uuid
  version     Int
  versionLabel String?      @map("version_label") @db.VarChar(100)
  nodes       Json          @default("[]")
  edges       Json          @default("[]")
  startNodeId String        @map("start_node_id") @db.VarChar(50)
  status      VersionStatus @default(DRAFT)
  changelog   String?       @db.Text
  createdAt   DateTime      @default(now()) @map("created_at")
  createdById String?       @map("created_by_id") @db.Uuid

  createdBy   User?          @relation(fields: [createdById], references: [id])
  scenario    Scenario       @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  licenses    UserLicense[]
  purchases   Purchase[]

  @@unique([scenarioId, version])
  @@index([scenarioId])
  @@index([status])
  @@map("scenario_versions")
}

// ============================================================
// UserLicense — активная лицензия пользователя
// ============================================================

enum LicenseStatus {
  ACTIVE
  REVOKED
  EXPIRED
  SUSPENDED
}

enum RevocationReason {
  CHARGEBACK
  FRAUD
  REFUND
  VIOLATION
  SUPPORT
}

model UserLicense {
  id              String          @id @default(uuid()) @db.Uuid
  userId          String          @map("user_id") @db.Uuid
  listingId       String          @map("listing_id") @db.Uuid
  scenarioVersionId String        @map("scenario_version_id") @db.Uuid
  licenseType     LicenseType     @default(SINGLE) @map("license_type")
  status          LicenseStatus   @default(ACTIVE)
  activationsUsed Int             @default(0) @map("activations_used")
  activationsLimit Int            @default(0) @map("activations_limit") // 0 = ∞
  expiresAt       DateTime?       @map("expires_at")
  updatePolicy    UpdatePolicy    @default(ALL_UPDATES) @map("update_policy")
  purchasedAt     DateTime        @default(now()) @map("purchased_at")
  revokedAt       DateTime?       @map("revoked_at")
  revokedReason   RevocationReason? @map("revoked_reason")
  revokedBy       String?         @map("revoked_by") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  listing         MarketplaceListing @relation(fields: [listingId], references: [id])
  scenarioVersion ScenarioVersion    @relation(fields: [scenarioVersionId], references: [id])
  user            User               @relation(fields: [userId], references: [id])
  runs            ScenarioRun[]

  @@index([userId])
  @@index([listingId])
  @@index([status])
  @@index([userId, listingId, status])
  @@map("user_licenses")
}

// ============================================================
// ScenarioRun — запуск сценария
// ============================================================

enum RunStatus {
  RUNNING
  COMPLETED
  ABORTED
}

model ScenarioRun {
  id          String    @id @default(uuid()) @db.Uuid
  scenarioId  String    @map("scenario_id") @db.Uuid
  organizerId String    @map("organizer_id") @db.Uuid
  licenseId   String    @map("license_id") @db.Uuid
  gameId      String?   @map("game_id") @db.Uuid
  status      RunStatus @default(RUNNING)
  startedAt   DateTime  @default(now()) @map("started_at")
  endedAt     DateTime? @map("ended_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  license  UserLicense @relation(fields: [licenseId], references: [id])
  organizer User       @relation(fields: [organizerId], references: [id])

  @@index([organizerId])
  @@index([licenseId])
  @@index([scenarioId])
  @@index([gameId])
  @@index([startedAt])
  @@map("scenario_runs")
}

// ============================================================
// Purchase — снапшот покупки
// ============================================================

enum PurchaseStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
  CANCELLED
}

model Purchase {
  id          String         @id @default(uuid()) @db.Uuid
  listingId   String         @map("listing_id") @db.Uuid
  scenarioVersionId String   @map("scenario_version_id") @db.Uuid
  buyerId     String         @map("buyer_id") @db.Uuid

  // Снапшот на момент покупки
  listingSnapshotTitle   String   @map("listing_snapshot_title") @db.VarChar(255)
  listingSnapshotVersion String   @map("listing_snapshot_version") @db.VarChar(50)
  listingSnapshotPrice   Decimal  @map("listing_snapshot_price") @db.Decimal(10, 2)

  licenseType LicenseType    @default(SINGLE) @map("license_type")
  price       Decimal        @db.Decimal(10, 2)
  commission  Decimal        @db.Decimal(10, 2)
  royalty     Decimal        @db.Decimal(10, 2)
  status      PurchaseStatus @default(PENDING)
  paymentId   String?        @map("payment_id") @db.VarChar(255)
  createdAt   DateTime       @default(now()) @map("created_at")
  completedAt DateTime?      @map("completed_at")

  listing         MarketplaceListing @relation(fields: [listingId], references: [id])
  scenarioVersion ScenarioVersion    @relation(fields: [scenarioVersionId], references: [id])
  buyer           User               @relation(fields: [buyerId], references: [id])
  earnings        AuthorEarning[]

  @@index([listingId])
  @@index([buyerId])
  @@index([status])
  @@index([createdAt])
  @@map("purchases")
}

// ============================================================
// FavoriteListing — избранное
// ============================================================

model FavoriteListing {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  listingId String   @map("listing_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  listing MarketplaceListing @relation("ListingFavorites", fields: [listingId], references: [id], onDelete: Cascade)
  user    User               @relation(fields: [userId], references: [id])

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@map("favorite_listings")
}

// ============================================================
// Cart / CartItem — корзина
// ============================================================

model Cart {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @unique @map("user_id") @db.Uuid
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id])
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid()) @db.Uuid
  cartId    String   @map("cart_id") @db.Uuid
  listingId String   @map("listing_id") @db.Uuid
  licenseType LicenseType @default(SINGLE) @map("license_type")
  createdAt DateTime @default(now()) @map("created_at")

  cart    Cart               @relation(fields: [cartId], references: [id], onDelete: Cascade)
  listing MarketplaceListing @relation(fields: [listingId], references: [id])

  @@unique([cartId, listingId])
  @@index([cartId])
  @@index([listingId])
  @@map("cart_items")
}

// ============================================================
// PromoCode — промокоды
// ============================================================

enum PromoCodeType {
  PERCENTAGE
  FIXED
}

enum PromoCodeStatus {
  ACTIVE
  EXPIRED
  DISABLED
}

model PromoCode {
  id          String          @id @default(uuid()) @db.Uuid
  code        String          @unique @db.VarChar(50)
  type        PromoCodeType   @default(PERCENTAGE)
  value       Decimal         @db.Decimal(10, 2) // процент или сумма
  maxUses     Int             @default(0) // 0 = безлимит
  usedCount   Int             @default(0) @map("used_count")
  minAmount   Decimal?        @map("min_amount") @db.Decimal(10, 2)
  maxAmount   Decimal?        @map("max_amount") @db.Decimal(10, 2)
  listingId   String?         @map("listing_id") @db.Uuid // null = на всё
  status      PromoCodeStatus @default(ACTIVE)
  expiresAt   DateTime?       @map("expires_at")
  createdById String          @map("created_by_id") @db.Uuid
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  createdBy User @relation(fields: [createdById], references: [id])

  @@index([code])
  @@index([status])
  @@index([listingId])
  @@map("promo_codes")
}

// ============================================================
// MarketplaceReview — отзывы на сценарии
// ============================================================

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model MarketplaceReview {
  id          String       @id @default(uuid()) @db.Uuid
  listingId   String       @map("listing_id") @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  rating      Int
  text        String?      @db.Text
  status      ReviewStatus @default(PENDING)
  moderatedBy String?      @map("moderated_by") @db.Uuid
  moderatedAt DateTime?    @map("moderated_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  listing MarketplaceListing @relation(fields: [listingId], references: [id])
  user    User               @relation(fields: [userId], references: [id])

  @@unique([listingId, userId])
  @@index([listingId])
  @@index([userId])
  @@index([status])
  @@map("marketplace_reviews")
}

// ============================================================
// AuthorEarning — доход автора
// ============================================================

enum EarningStatus {
  PENDING
  AVAILABLE
  PAID_OUT
  CANCELLED
}

model AuthorEarning {
  id         String        @id @default(uuid()) @db.Uuid
  authorId   String        @map("author_id") @db.Uuid
  purchaseId String        @map("purchase_id") @db.Uuid
  amount     Decimal       @db.Decimal(10, 2)
  commission Decimal       @db.Decimal(10, 2)
  royalty    Decimal       @db.Decimal(10, 2)
  status     EarningStatus @default(PENDING)
  payoutId   String?       @map("payout_id") @db.Uuid
  createdAt  DateTime      @default(now()) @map("created_at")

  author   User     @relation(fields: [authorId], references: [id])
  purchase Purchase @relation(fields: [purchaseId], references: [id])
  payout   Payout?  @relation(fields: [payoutId], references: [id])

  @@index([authorId])
  @@index([purchaseId])
  @@index([status])
  @@index([payoutId])
  @@map("author_earnings")
}

// ============================================================
// Payout — выплата автору
// ============================================================

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

model Payout {
  id           String       @id @default(uuid()) @db.Uuid
  authorId     String       @map("author_id") @db.Uuid
  amount       Decimal      @db.Decimal(10, 2)
  status       PayoutStatus @default(PENDING)
  paymentId    String?      @map("payment_id") @db.VarChar(255)
  failedReason String?      @map("failed_reason")
  processedAt  DateTime?    @map("processed_at")
  processedBy  String?      @map("processed_by") @db.Uuid
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  author   User            @relation(fields: [authorId], references: [id])
  earnings AuthorEarning[]

  @@index([authorId])
  @@index([status])
  @@index([createdAt])
  @@map("payouts")
}

// ============================================================
// MarketplaceAnalytics — аналитика
// ============================================================

enum AnalyticsPeriod {
  DAY
  WEEK
  MONTH
}

model MarketplaceAnalytics {
  id             String          @id @default(uuid()) @db.Uuid
  listingId      String          @map("listing_id") @db.Uuid
  views          Int             @default(0)
  favorites      Int             @default(0)
  sales          Int             @default(0)
  conversionRate Float           @default(0) @map("conversion_rate")
  avgRating      Float           @default(0) @map("avg_rating")
  reviewsCount   Int             @default(0) @map("reviews_count")
  period         AnalyticsPeriod @default(DAY)
  date           DateTime        @map("date")
  createdAt      DateTime        @default(now()) @map("created_at")

  listing MarketplaceListing @relation(fields: [listingId], references: [id])

  @@unique([listingId, period, date])
  @@index([listingId])
  @@index([period, date])
  @@map("marketplace_analytics")
}

// ============================================================
// MEDIA
// ============================================================

model Media {
  id           String   @id @default(uuid()) @db.Uuid
  filename     String   @db.VarChar(255)
  originalName String   @map("original_name") @db.VarChar(255)
  mimeType     String   @map("mime_type") @db.VarChar(100)
  size         Int
  path         String
  url          String
  gameId       String?  @map("game_id") @db.Uuid
  teamId       String?  @map("team_id") @db.Uuid
  uploadedById String?  @map("uploaded_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  game         Game?    @relation(fields: [gameId], references: [id])
  team         Team?    @relation(fields: [teamId], references: [id])
  uploadedBy   User?    @relation("MediaUploader", fields: [uploadedById], references: [id])

  @@index([gameId])
  @@index([teamId])
  @@index([uploadedById])
}

// ============================================================
// REVIEW
// ============================================================

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  gameId    String   @map("game_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  rating    Int
  text      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([gameId])
  @@index([userId])
  @@index([rating])
}

// ============================================================
// COMMENT
// ============================================================

model Comment {
  id        String    @id @default(uuid()) @db.Uuid
  gameId    String    @map("game_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  text      String
  parentId  String?   @map("parent_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  game      Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  user      User      @relation(fields: [userId], references: [id])

  @@index([gameId])
  @@index([userId])
  @@index([parentId])
}

// ============================================================
// HEATMAP DATA
// ============================================================

model HeatmapData {
  id        String   @id @default(uuid()) @db.Uuid
  gameId    String   @map("game_id") @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  lat       Decimal  @db.Decimal(10, 8)
  lng       Decimal  @db.Decimal(11, 8)
  nodeId    String?  @map("node_id") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([teamId])
  @@index([createdAt])
}

// ============================================================
// ORGANIZER APPLICATION
// ============================================================

model OrganizerApplication {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @unique @map("user_id") @db.Uuid
  city            String    @db.VarChar(100)
  phone           String    @db.VarChar(20)
  telegram        String?   @db.VarChar(100)
  experience      String?
  status          String    @default("PENDING") @db.VarChar(50)
  rejectionReason String?   @map("rejection_reason")
  reviewedBy      String?   @map("reviewed_by") @db.Uuid
  reviewedAt      DateTime? @map("reviewed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  reviewer        User?     @relation("ApplicationReviewer", fields: [reviewedBy], references: [id])
  user            User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================
// USER LIMITS (Entitlements / Монетизация)
// ============================================================

model UserLimits {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  tier      Tier     @default(FREE)

  // AI-помощник
  aiGenerationsToday Int  @default(0) @map("ai_generations_today")
  aiGenerationsLimit Int  @default(3) @map("ai_generations_limit")
  aiGenerationsResetAt DateTime? @map("ai_generations_reset_at")

  // Лимиты организатора
  gamesLimit Int @default(1) @map("games_limit")
  teamsLimit Int @default(10) @map("teams_limit")

  // Аналитика
  analyticsLevel String @default("basic") @map("analytics_level") @db.VarChar(20)

  // Доступ к маркетплейсу
  marketplaceAccess Boolean @default(false) @map("marketplace_access")
  exportEnabled     Boolean @default(false) @map("export_enabled")

  // Срок действия тарифа
  expiresAt DateTime? @map("expires_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_limits")
}

// ============================================================
// BILLING LEDGER (Финансовая книга — v2)
// ============================================================

model LedgerEntry {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50) // payment | refund | payout | commission | adjustment
  amount    Decimal  @db.Decimal(10, 2)
  currency  String   @default("RUB") @db.VarChar(10)
  relatedId String?  @map("related_id") @db.VarChar(255)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("ledger_entries")
}

// ============================================================
// PAYMENT (Платежи — v2 full)
// ============================================================

model Payment {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  tier          Tier
  amount        Decimal   @db.Decimal(10, 2)
  currency      String    @default("RUB") @db.VarChar(10)
  status        String    @default("pending") @db.VarChar(50) // pending | paid | failed | refunded
  provider      String?   @db.VarChar(50) // stripe | yookassa | test
  providerId    String?   @map("provider_id") @db.VarChar(255)
  paidAt        DateTime? @map("paid_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

