generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USER — Aggregate Root
// Одна таблица с JSON-полями для MVP.
// Потом разделим на отдельные сущности.
// ============================================================

model User {
  // === IDENTITY ===
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @db.VarChar(255)
  username  String   @unique @db.VarChar(100)
  slug      String   @unique @db.VarChar(150)
  roles     Role[]   @default([PLAYER])
  status    UserStatus @default(ACTIVE)
  verified  Json     @default("{}") @map("verified") // { email: bool, phone: bool, telegram: bool }
  version   Int      @default(1) // Optimistic locking

  // === PROFILE (JSON) ===
  // { avatar, bio, city, socialLinks: { tg, vk, discord, youtube, github }, favorites: { games, scenarios, authors }, metadata }
  profile   Json     @default("{}") @map("profile")

  // === SETTINGS (JSON) ===
  // { language, timezone, theme, notifications: { email, telegram, push }, privacy: { showCity, showContacts, showStats, showAchievements } }
  settings  Json     @default("{}") @map("settings")

  // === SECURITY (JSON) — управляется Auth Service ===
  // { lastLoginAt, failedLoginAttempts, passwordChangedAt, trustedDevices: [] }
  security  Json     @default("{}") @map("security")

  // === REPUTATION (JSON) — вычисляется системой ===
  // { rating, trustScore, reviewsCount, violations, completedGames, achievements: [] }
  reputationData Json @default("{}") @map("reputation_data")

  // === AI PROFILE (JSON) — принадлежит AI Service ===
  // { preferences: { genres, averageTeamSize, averageGameDuration, favoriteDifficulty }, memory: { knownFacts, lastConversation, memoryVersion }, history: { recommendedScenarios, previousActions, feedback }, context: { lastAgentAction, activeGoals, personality }, embeddings: [] }
  aiProfile  Json    @default("{}") @map("ai_profile")

  // === CAPABILITIES (JSON) — вычисляются системой ===
  capabilities Json  @default("[]") @map("capabilities")
  featureFlags Json  @default("{}") @map("feature_flags")

  // === AUDIT ===
  lastSeenAt DateTime? @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at") // Soft Delete

  // === СТАРЫЕ ПОЛЯ (обратная совместимость) ===
  name             String           @db.VarChar(100)
  passwordHash     String           @map("password_hash") @db.VarChar(255)
  avatarUrl        String?          @map("avatar_url")
  role             Role             @default(PLAYER)
  contacts         Json             @default("{}")
  organizerStatus  OrganizerStatus  @default(NOT_APPLIED) @map("organizer_status")
  organizerApprovedAt DateTime?     @map("organizer_approved_at")
  gamesConducted   Int              @default(0) @map("games_conducted")
  gamesCreated     Int              @default(0) @map("games_created")
  organizerApplicationId String?    @map("organizer_application_id") @db.Uuid
  scenariosCreated Int              @default(0) @map("scenarios_created")
  rating           Float            @default(0)
  reputation       Int              @default(0)
  legacyAchievements Json           @default("[]") @map("achievements") @db.Json
  lastLoginAt      DateTime?        @map("last_login_at")
  bio              String?
  city             String?          @db.VarChar(100)
  telegram         String?          @db.VarChar(100)
  vk               String?          @db.VarChar(255)
  whatsapp         String?          @db.VarChar(100)

  // === RELATIONS ===
  comments               Comment[]
  games                  Game[]
  licenses               License[]
  mediaUploads           Media[]                @relation("MediaUploader")
  reviewedApplications   OrganizerApplication[] @relation("ApplicationReviewer")
  organizerApplication   OrganizerApplication?
  purchases              Purchase[]
  reviews                Review[]
  scenarios              Scenario[]
  createdVersions        ScenarioVersion[]
  captainTeams           Team[]                 @relation("TeamCaptain")
  teamMemberships        TeamMember[]
  auditLogs              AuditLog[]
  followers              Follow[]               @relation("FollowTarget")
  following              Follow[]               @relation("FollowSource")
  activityLogs           ActivityLog[]
  teamInvitesReceived    TeamInvite[]           @relation("InvitedUser")
  teamInvitesSent        TeamInvite[]           @relation("InvitedByUser")
  joinRequests           JoinRequest[]
  joinRequestsResolved   JoinRequest[]          @relation("JoinRequestResolver")
  transfersFrom          OwnershipTransfer[]    @relation("TransferFrom")
  transfersTo            OwnershipTransfer[]    @relation("TransferTo")
  gameComments           GameComment[]
  gameQuestions          GameQuestion[]
  notifications          Notification[]
  achievements           UserAchievement[]

  @@index([email])
  @@index([username])
  @@index([slug])
  @@index([status])
  @@index([city])
  @@index([rating])
}

// ============================================================
// FOLLOW SYSTEM
// ============================================================

model Follow {
  id          String   @id @default(uuid()) @db.Uuid
  followerId  String   @map("follower_id") @db.Uuid
  followingId String   @map("following_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  follower    User     @relation("FollowSource", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("FollowTarget", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)
  entityId  String   @map("entity_id") @db.VarChar(100)
  oldValue  Json?
  newValue  Json?
  ip        String?  @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entity, entityId])
}

// ============================================================
// USER ACHIEVEMENT (достижения пользователя)
// ============================================================

model UserAchievement {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  type        String   @db.VarChar(50)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  icon        String   @default("🏆") @db.VarChar(50)
  unlockedAt  DateTime @default(now()) @map("unlocked_at")
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, type])
  @@index([userId])
  @@index([type])
}

// ============================================================
// NOTIFICATION (уведомления пользователя)
// ============================================================

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(255)
  message   String?  @db.Text
  link      String?  @db.VarChar(500)
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
}

// ============================================================
// ACTIVITY LOG (лента действий пользователя)
// ============================================================

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

// ============================================================
// GAME — Aggregate Root
// ============================================================

model Game {
  id                String           @id @default(uuid()) @db.Uuid
  slug              String           @unique @db.VarChar(150)
  title             String           @db.VarChar(255)
  description       String?
  city              String           @db.VarChar(100)
  address           String?          @db.VarChar(500)
  date              DateTime
  time              String           @db.VarChar(5) // HH:mm
  duration          Int              @map("duration")
  price             Decimal          @default(0) @db.Decimal(10, 2)
  maxTeams          Int              @default(50) @map("max_teams")
  shareLink         String           @unique @map("share_link") @db.VarChar(50)
  imageUrl          String?          @map("image_url")
  bannerUrl         String?          @map("banner_url")
  tags              String[]         @default([]) @map("tags")
  status            GameStatus       @default(DRAFT)
  moderationStatus  ModerationStatus @default(PENDING) @map("moderation_status")
  moderationComment String?          @map("moderation_comment")
  version           Int              @default(1) // Optimistic locking

  // Настройки старта
  autoStart         Boolean          @default(false) @map("auto_start")
  autoStartDelay    Int              @default(0) @map("auto_start_delay")
  allowEarlyStart   Boolean          @default(true) @map("allow_early_start")
  startBuffer       Int              @default(15) @map("start_buffer")
  allowLateRegistration Boolean       @default(false) @map("allow_late_registration")

  organizerId       String           @map("organizer_id") @db.Uuid
  scenarioId        String?          @map("scenario_id") @db.Uuid

  publishedAt       DateTime?        @map("published_at")
  submittedAt       DateTime?        @map("submitted_at")
  moderatedAt       DateTime?        @map("moderated_at")
  startedAt         DateTime?        @map("started_at")
  finishedAt        DateTime?        @map("finished_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  deletedAt         DateTime?        @map("deleted_at")

  // Relations
  organizer         User             @relation(fields: [organizerId], references: [id])
  scenario          Scenario?        @relation(fields: [scenarioId], references: [id])
  comments          Comment[]
  events            Event[]
  gameTeams         GameTeam[]
  registrations     GameRegistration[]
  gameComments           GameComment[]
  gameQuestions          GameQuestion[]
  heatmapData       HeatmapData[]
  media             Media[]
  reviews           Review[]

  @@index([shareLink])
  @@index([organizerId])
  @@index([status])
  @@index([city])
  @@index([date])
  @@index([scenarioId])
  @@index([moderationStatus])
  @@index([slug])
  @@index([deletedAt])
}

// ============================================================
// GAME REGISTRATION
// ============================================================

model GameRegistration {
  id        String             @id @default(uuid()) @db.Uuid
  gameId    String             @map("game_id") @db.Uuid
  teamId    String             @map("team_id") @db.Uuid
  status    RegistrationStatus @default(REGISTERED)
  readyAt   DateTime?          @map("ready_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  game      Game               @relation(fields: [gameId], references: [id], onDelete: Cascade)
  team      Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([gameId, teamId])
  @@index([gameId])
  @@index([teamId])
  @@index([status])
}

// ============================================================
// GAME COMMENT (обсуждения игры)
// ============================================================

model GameComment {
  id        String   @id @default(uuid()) @db.Uuid
  gameId    String   @map("game_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  text      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])

  @@index([gameId])
  @@index([authorId])
  @@index([createdAt])
}

// ============================================================
// GAME QUESTION (вопросы организатору)
// ============================================================

model GameQuestion {
  id         String    @id @default(uuid()) @db.Uuid
  gameId     String    @map("game_id") @db.Uuid
  authorId   String    @map("author_id") @db.Uuid
  question   String    @db.Text
  answer     String?   @db.Text
  answeredAt DateTime? @map("answered_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  game       Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  author     User      @relation(fields: [authorId], references: [id])

  @@index([gameId])
  @@index([authorId])
  @@index([answeredAt])
}

// ============================================================
// SCENARIO
// ============================================================

model Scenario {
  id               String            @id @default(uuid()) @db.Uuid
  name             String            @db.VarChar(255)
  description      String?
  authorId         String            @map("author_id") @db.Uuid
  version          Int               @default(1)
  isPublished      Boolean           @default(false) @map("is_published")
  price            Decimal?          @db.Decimal(10, 2)
  licenseType      String?           @map("license_type") @db.VarChar(50)
  nodes            Json              @default("[]")
  edges            Json              @default("[]")
  startNodeId      String            @map("start_node_id") @db.VarChar(50)
  metadata         Json              @default("{}")
  validationStatus String?           @map("validation_status") @db.VarChar(50)
  validationErrors Json?             @map("validation_errors")
  publishedAt      DateTime?         @map("published_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")
  games            Game[]
  licenses         License[]
  purchases        Purchase[]
  author           User              @relation(fields: [authorId], references: [id])
  versions         ScenarioVersion[]

  @@index([authorId])
  @@index([isPublished])
  @@index([price])
  @@index([validationStatus])
}

model ScenarioVersion {
  id          String   @id @default(uuid()) @db.Uuid
  scenarioId  String   @map("scenario_id") @db.Uuid
  version     Int
  nodes       Json     @default("[]")
  edges       Json     @default("[]")
  startNodeId String   @map("start_node_id") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")
  createdById String?  @map("created_by_id") @db.Uuid
  createdBy   User?    @relation(fields: [createdById], references: [id])
  scenario    Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@unique([scenarioId, version])
  @@index([scenarioId])
}

// ============================================================
// TEAM — Aggregate Root
// ============================================================

model Team {
  id            String         @id @default(uuid()) @db.Uuid
  name          String         @db.VarChar(100)
  slug          String         @unique @db.VarChar(150)
  description   String?        @db.Text
  avatar        String?        @db.VarChar(500)
  banner        String?        @db.VarChar(500)
  city          String?        @db.VarChar(100)
  country       String?        @db.VarChar(100)
  website       String?        @db.VarChar(500)
  socials       Json           @default("{}") @map("socials") // { discord, vk, telegram, youtube }
  captainId     String         @map("captain_id") @db.Uuid
  status        TeamStatus     @default(ACTIVE) @map("status")
  privacy       TeamVisibility @default(PUBLIC) @map("privacy")
  joinPolicy    JoinPolicy     @default(INVITE_ONLY) @map("join_policy")
  tags          String[]       @default([]) @map("tags")
  version       Int            @default(1) // Optimistic locking
  score         Int            @default(0)
  penalties     Int            @default(0)
  finishedAt    DateTime?      @map("finished_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at") // Soft Delete

  // Limits (JSON)
  maxMembers           Int  @default(20) @map("max_members")
  maxInvitesPerDay     Int  @default(10) @map("max_invites_per_day")
  maxPendingRequests   Int  @default(5) @map("max_pending_requests")
  maxChatMessagesPerMinute Int @default(30) @map("max_chat_messages_per_minute")

  // Relations
  captain       User           @relation("TeamCaptain", fields: [captainId], references: [id])
  members       TeamMember[]
  invites       TeamInvite[]
  joinRequests  JoinRequest[]
  transfers     OwnershipTransfer[]
  events        Event[]
  games         GameTeam[]
  registrations GameRegistration[]
  heatmapData   HeatmapData[]
  inventory     Inventory?
  media         Media[]
  resources     Resource?
  sessionStates SessionState[]

  @@index([captainId])
  @@index([status])
  @@index([slug])
  @@index([city])
  @@index([deletedAt])
}

model TeamMember {
  id        String      @id @default(uuid()) @db.Uuid
  teamId    String      @map("team_id") @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  role      TeamRole    @default(MEMBER) @map("role")
  status    MemberStatus @default(ACTIVE) @map("status")
  joinedAt  DateTime    @default(now()) @map("joined_at")
  leftAt    DateTime?   @map("left_at")
  lastActiveAt DateTime? @map("last_active_at")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  team      Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])

  @@unique([teamId, userId], name: "team_member_unique")
  @@index([teamId])
  @@index([userId])
  @@index([role])
  @@index([status])
}

// ============================================================
// TEAM INVITE
// ============================================================

model TeamInvite {
  id            String       @id @default(uuid()) @db.Uuid
  teamId        String       @map("team_id") @db.Uuid
  invitedUserId String       @map("invited_user_id") @db.Uuid
  invitedBy     String       @map("invited_by") @db.Uuid
  token         String       @unique @db.VarChar(255)
  message       String?      @db.Text
  status        InviteStatus @default(PENDING) @map("status")
  expiresAt     DateTime     @map("expires_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  team          Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedUser   User         @relation("InvitedUser", fields: [invitedUserId], references: [id])
  invitedByUser User         @relation("InvitedByUser", fields: [invitedBy], references: [id])

  @@index([teamId])
  @@index([invitedUserId])
  @@index([token])
  @@index([status])
  @@index([expiresAt])
}

// ============================================================
// JOIN REQUEST
// ============================================================

model JoinRequest {
  id         String            @id @default(uuid()) @db.Uuid
  teamId     String            @map("team_id") @db.Uuid
  userId     String            @map("user_id") @db.Uuid
  message    String?           @db.Text
  status     JoinRequestStatus @default(PENDING) @map("status")
  resolvedBy String?           @map("resolved_by") @db.Uuid
  createdAt  DateTime          @default(now()) @map("created_at")
  resolvedAt DateTime?         @map("resolved_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  team       Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id])
  resolver   User?             @relation("JoinRequestResolver", fields: [resolvedBy], references: [id])

  @@unique([teamId, userId, status], name: "join_request_unique")
  @@index([teamId])
  @@index([userId])
  @@index([status])
}

// ============================================================
// OWNERSHIP TRANSFER
// ============================================================

model OwnershipTransfer {
  id          String          @id @default(uuid()) @db.Uuid
  teamId      String          @map("team_id") @db.Uuid
  fromUserId  String          @map("from_user_id") @db.Uuid
  toUserId    String          @map("to_user_id") @db.Uuid
  status      TransferStatus  @default(PENDING) @map("status")
  expiresAt   DateTime        @map("expires_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  resolvedAt  DateTime?       @map("resolved_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  team        Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  fromUser    User            @relation("TransferFrom", fields: [fromUserId], references: [id])
  toUser      User            @relation("TransferTo", fields: [toUserId], references: [id])

  @@index([teamId])
  @@index([status])
  @@index([expiresAt])
}

model GameTeam {
  id       String   @id @default(uuid()) @db.Uuid
  teamId   String   @map("team_id") @db.Uuid
  gameId   String   @map("game_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at")
  game     Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, gameId])
  @@index([teamId])
  @@index([gameId])
}

// ============================================================
// INVENTORY & RESOURCES
// ============================================================

model Inventory {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @unique @map("team_id") @db.Uuid
  items     Json     @default("[]")
  capacity  Int      @default(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

model Resource {
  id         String   @id @default(uuid()) @db.Uuid
  teamId     String   @unique @map("team_id") @db.Uuid
  score      Int      @default(0)
  reputation Int      @default(0)
  money      Int      @default(0)
  energy     Int      @default(100)
  lives      Int      @default(3)
  custom     Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

// ============================================================
// SESSION STATE
// ============================================================

model SessionState {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  state     Json
  sequence  Int
  createdAt DateTime @default(now()) @map("created_at")
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([sequence])
}

// ============================================================
// EVENT (Game Engine Events)
// ============================================================

model Event {
  id        String   @id @default(uuid()) @db.Uuid
  type      String   @db.VarChar(50)
  gameId    String   @map("game_id") @db.Uuid
  teamId    String?  @map("team_id") @db.Uuid
  nodeId    String?  @map("node_id") @db.VarChar(50)
  payload   Json     @default("{}")
  timestamp DateTime
  sequence  Int
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  game      Game     @relation(fields: [gameId], references: [id])
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([teamId])
  @@index([type])
  @@index([sequence])
  @@index([createdAt])
  @@index([gameId, createdAt])
  @@index([teamId, createdAt])
}

// ============================================================
// PURCHASE & LICENSE
// ============================================================

model Purchase {
  id          String    @id @default(uuid()) @db.Uuid
  scenarioId  String    @map("scenario_id") @db.Uuid
  buyerId     String    @map("buyer_id") @db.Uuid
  licenseType String    @map("license_type") @db.VarChar(50)
  amount      Decimal   @db.Decimal(10, 2)
  commission  Decimal   @db.Decimal(10, 2)
  royalty     Decimal   @db.Decimal(10, 2)
  status      String    @default("pending") @db.VarChar(50)
  paymentId   String?   @map("payment_id") @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")
  buyer       User      @relation(fields: [buyerId], references: [id])
  scenario    Scenario  @relation(fields: [scenarioId], references: [id])

  @@index([scenarioId])
  @@index([buyerId])
  @@index([status])
}

model License {
  id          String    @id @default(uuid()) @db.Uuid
  scenarioId  String    @map("scenario_id") @db.Uuid
  buyerId     String    @map("buyer_id") @db.Uuid
  licenseType String    @map("license_type") @db.VarChar(50)
  city        String?   @db.VarChar(100)
  price       Decimal   @db.Decimal(10, 2)
  status      String    @default("active") @db.VarChar(50)
  expiresAt   DateTime? @map("expires_at")
  purchasedAt DateTime  @default(now()) @map("purchased_at")
  buyer       User      @relation(fields: [buyerId], references: [id])
  scenario    Scenario  @relation(fields: [scenarioId], references: [id])

  @@index([scenarioId])
  @@index([buyerId])
  @@index([status])
}

// ============================================================
// MEDIA
// ============================================================

model Media {
  id           String   @id @default(uuid()) @db.Uuid
  filename     String   @db.VarChar(255)
  originalName String   @map("original_name") @db.VarChar(255)
  mimeType     String   @map("mime_type") @db.VarChar(100)
  size         Int
  path         String
  url          String
  gameId       String?  @map("game_id") @db.Uuid
  teamId       String?  @map("team_id") @db.Uuid
  uploadedById String?  @map("uploaded_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  game         Game?    @relation(fields: [gameId], references: [id])
  team         Team?    @relation(fields: [teamId], references: [id])
  uploadedBy   User?    @relation("MediaUploader", fields: [uploadedById], references: [id])

  @@index([gameId])
  @@index([teamId])
  @@index([uploadedById])
}

// ============================================================
// REVIEW
// ============================================================

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  gameId    String   @map("game_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  rating    Int
  text      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([gameId])
  @@index([userId])
  @@index([rating])
}

// ============================================================
// COMMENT
// ============================================================

model Comment {
  id        String    @id @default(uuid()) @db.Uuid
  gameId    String    @map("game_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  text      String
  parentId  String?   @map("parent_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  game      Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  user      User      @relation(fields: [userId], references: [id])

  @@index([gameId])
  @@index([userId])
  @@index([parentId])
}

// ============================================================
// HEATMAP DATA
// ============================================================

model HeatmapData {
  id        String   @id @default(uuid()) @db.Uuid
  gameId    String   @map("game_id") @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  lat       Decimal  @db.Decimal(10, 8)
  lng       Decimal  @db.Decimal(11, 8)
  nodeId    String?  @map("node_id") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([teamId])
  @@index([createdAt])
}

// ============================================================
// ORGANIZER APPLICATION
// ============================================================

model OrganizerApplication {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @unique @map("user_id") @db.Uuid
  city            String    @db.VarChar(100)
  phone           String    @db.VarChar(20)
  telegram        String?   @db.VarChar(100)
  experience      String?
  status          String    @default("PENDING") @db.VarChar(50)
  rejectionReason String?   @map("rejection_reason")
  reviewedBy      String?   @map("reviewed_by") @db.Uuid
  reviewedAt      DateTime? @map("reviewed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  reviewer        User?     @relation("ApplicationReviewer", fields: [reviewedBy], references: [id])
  user            User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

